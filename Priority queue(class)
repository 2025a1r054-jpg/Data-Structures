#include <stdio.h>
#include <stdlib.h>

#define MAX 100

struct Queue {
    int data;
    int priority;
};

struct Queue pqueue[MAX];
int front = -1, rear = -1;

int isEmpty() {
    return front == -1;
}

int isFull() {
    return rear == MAX - 1;
}

void enqueue(int data, int priority) {
    if (isFull()) {
        printf("Queue Overflow!\n");
        return;
    }
    if (front == -1) front = 0;
    rear++;
    pqueue[rear].data = data;
    pqueue[rear].priority = priority;
    printf("Element inserted!\n");
}

int gettingHighestpriority() {
    int max = pqueue[0].priority;
    int index = 0;
    for (int i = 1; i <= rear; i++) {
        if (pqueue[i].priority > max) {
            max = pqueue[i].priority;
            index = i;
        }
    }
    return index;
}

int dequeue() {
    if (isEmpty()) {
        printf("Queue Underflow!\n");
        return -1;
    }
    int index = gettingHighestpriority();
    int val = pqueue[index].data;
    for (int i = index; i < rear; i++) {
        pqueue[i] = pqueue[i + 1];
    }
    rear--;
    if (rear == -1) front = -1;
    return val;
}

void peek() {
    if (isEmpty()) {
        printf("Queue Underflow!\n");
        return;
    }
    int index = gettingHighestpriority();
    printf("%d\n", pqueue[index].data);
}

void display() {
    if (isEmpty()) {
        printf("Queue Underflow!\n");
        return;
    }
    for (int i = 0; i <= rear; i++) {
        printf("%d-->%d\n", pqueue[i].priority, pqueue[i].data);
    }
}

int main() {
    int choice, value, priority;
    while (1) {
        printf("1. Enqueue\n2. Dequeue\n3. Peek\n4. Display\n5. Exit\nEnter Choice: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1:
                printf("Enter value: ");
                scanf("%d", &value);
                printf("Enter priority: ");
                scanf("%d", &priority);
                enqueue(value, priority);
                break;
            case 2:
                value = dequeue();
                if (value != -1) printf("Dequeued: %d\n", value);
                break;
            case 3:
                peek();
                break;
            case 4:
                display();
                break;
            case 5:
                exit(0);
        }
    }
    return 0;
}
